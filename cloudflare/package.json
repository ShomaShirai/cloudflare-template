{
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "react-router dev",
    "preview": "wrangler dev",
    "preview-remote": "wrangler dev -r",
    "build": "react-router build",
    "deploy": "npm run build && wrangler deploy",
    "dry-run": "wrangler deploy --dry-run",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply app-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply app-db --remote",
    "cf-typegen": "wrangler types",
    "postinstall": "npm run cf-typegen",
    "typecheck": "npm run cf-typegen && react-router typegen && tsc -b"
  },
  "dependencies": {
    "drizzle-orm": "^0.44.7",
    "hono": "4.10.7",
    "isbot": "^5.1.32",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router": "^7.10.0"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.15.3",
    "@react-router/dev": "^7.10.0",
    "@tailwindcss/vite": "^4.1.17",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "drizzle-kit": "^0.31.7",
    "tailwindcss": "^4.1.17",
    "typescript": "^5.9.3",
    "vite": "npm:rolldown-vite@latest",
    "vite-tsconfig-paths": "^5.1.4",
    "wrangler": "^4.51.0"
  }
}
